# OpenWorker environment variables
# Copy to .env and fill in your values

# LLM providers (set whichever you use)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
DATABASE_URL=postgresql://user:pass@localhost:5432/openworker
# Local Postgres password used by docker-compose
POSTGRES_PASSWORD=change-me-openworker-dev

# Approval channel
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Optional: local LLM (Ollama)
OLLAMA_BASE_URL=http://ollama:11434

# Optional: voice (Layla only)
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...

# Host port overrides (change if another service holds the default)
# DB_HOST_PORT=5432
# N8N_HOST_PORT=5678
# API_HOST_PORT=8000

# Runtime
OPENWORKER_ENV=development
OPENWORKER_LOG_LEVEL=verbose
OPENWORKER_AUDIT_PATH=./audit.jsonl
